<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <MSDeployServiceURL>http://sqlserver-mcp/msdeploy.axd</MSDeployServiceURL>
    <DeployIisAppPath>sqlserver-mcp</DeployIisAppPath>
    <UserName>ruben</UserName>
    <Password>
    </Password>
    <AuthType>Basic</AuthType>
    <AllowUntrustedCertificate>true</AllowUntrustedCertificate>
    <EnableMSDeployBackup>true</EnableMSDeployBackup>
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <Configuration>Release</Configuration>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <EnvironmentName>Production</EnvironmentName>
    <_SavePWD>true</_SavePWD>
    <LastUsedBuildConfiguration />
    <LastUsedPlatform />
    <SiteUrlToLaunchAfterPublish>http://sqlserver-mcp</SiteUrlToLaunchAfterPublish>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <ProjectGuid>fa88fec5-d8fe-848d-33c2-ab2cecc66d10</ProjectGuid>
    <RemoteSitePhysicalPath />
    <SkipExtraFilesOnServer>true</SkipExtraFilesOnServer>
    <MSDeployPublishMethod>RemoteAgent</MSDeployPublishMethod>
    <EnableMsDeployAppOffline>true</EnableMsDeployAppOffline>
  </PropertyGroup>
</Project>
